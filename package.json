{
  "name": "@logto/docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "if test \"$NODE_ENV\" != \"production\" && test \"$CI\" != \"true\" ; then husky ; fi",
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "cp static/_redirects-docs static/_redirects && docusaurus build",
    "build:tutorials": "cp static/_redirects-tutorials static/_redirects && pnpm generate-tutorials && docusaurus build --config docusaurus-tutorials.config.ts",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear && pnpm remove-generated-tutorials && pnpm remove-generated-og-images",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "node write-heading-ids.mjs",
    "generate-tutorials": "node generate-tutorials.mjs",
    "remove-generated-tutorials": "find . -type f -name 'generated-*.mdx' -delete",
    "remove-generated-og-images": "find static-localized -type d -name og -exec rm -rf {} +",
    "lint": "eslint src docs tutorial i18n",
    "typecheck": "tsc"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "^3.9.2",
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/plugin-client-redirects": "3.10.1",
    "@docusaurus/plugin-content-blog": "3.10.1",
    "@docusaurus/plugin-content-docs": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/theme-classic": "3.10.1",
    "@docusaurus/theme-common": "3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@eslint/eslintrc": "^3.1.0",
    "@inkeep/cxkit-react": "^0.5.66",
    "@mdx-js/react": "^3.1.0",
    "@silverhand/eslint-config": "^6.0.0",
    "@silverhand/eslint-config-react": "^6.0.0",
    "@silverhand/essentials": "^2.9.2",
    "@silverhand/ts-config": "^6.0.0",
    "@silverhand/ts-config-react": "^6.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-modal": "^3.16.3",
    "arg": "^5.0.2",
    "clsx": "^2.1.1",
    "core-js": "^3.38.1",
    "docusaurus-plugin-remote-content": "^4.0.0",
    "docusaurus-plugin-sass": "^0.2.6",
    "dotenv": "^17.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-mdx": "^3.1.5",
    "execa": "^9.5.1",
    "https-proxy-agent": "^9.0.0",
    "husky": "^9.1.6",
    "js-cookie": "^3.0.7",
    "js-yaml": "^4.2.0",
    "lint-staged": "^16.0.0",
    "listr2": "^10.0.0",
    "openai": "^6.0.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.3.3",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-modal": "^3.16.1",
    "react-paginate": "^8.2.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.90.0",
    "satori": "^0.25.0",
    "sharp": "^0.34.0",
    "stylelint": "^17.0.0",
    "typescript": "~5.9.0",
    "zod": "^4.0.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "^20.11.0 || ^22.0.0"
  },
  "prettier": "@silverhand/eslint-config/.prettierrc",
  "pnpm": {
    "overrides": {
      "mermaid@>=11.0.0 <11.14.0": "^11.15.0",
      "@eslint/plugin-kit@<0.3.4": "^0.3.4",
      "on-headers@<1.1.0": "^1.1.0",
      "qs@>=6.7.0 <=6.15.1": "^6.15.2",
      "minimatch@<3.1.4": "^3.1.4",
      "svgo@>=3.0.0 <3.3.3": "^3.3.3",
      "flatted@<=3.4.1": "^3.4.2",
      "path-to-regexp@<0.1.13": "^0.1.13",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=4.0.0 <5.0.6": "^5.0.6",
      "node-forge@<1.4.0": "^1.4.0",
      "picomatch@<2.3.2": "^2.3.2",
      "yaml@>=2.0.0 <2.8.3": "^2.8.3",
      "lodash-es@<=4.17.23": "^4.18.0",
      "lodash@<=4.17.23": "^4.18.0",
      "follow-redirects@<=1.15.11": "^1.16.0",
      "postcss@<8.5.10": "^8.5.10",
      "immutable@>=5.0.0 <5.1.5": "^5.1.5",
      "dompurify@>=1.0.10 <3.4.0": "^3.4.0",
      "fast-uri@<=3.1.1": "^3.1.2",
      "webpack-dev-server@<=5.2.3": "^5.2.4",
      "ws@>=8.0.0 <8.20.1": "^8.20.1",
      "serialize-javascript@>=5.0.0 <7.0.5": "^7.0.5",
      "uuid@<11.1.1": "^11.1.1",
      "axios@>=1.0.0 <1.16.0": "^1.16.0",
      "@babel/plugin-transform-modules-systemjs@>=7.12.0 <=7.29.3": "^7.29.4",
      "shell-quote@>=1.1.0 <=1.8.3": "^1.8.4",
      "joi@<17.13.4": "^17.13.4"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "core-js-pure",
      "sharp"
    ]
  }
}
